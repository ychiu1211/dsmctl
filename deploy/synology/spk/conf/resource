{
  "docker-project": {
    "preload-image": "image.tar.gz",
    "projects": [{
      "name": "dsmctl-gateway",
      "path": "project",
      "build_params": {
        "force_pull": false,
        "force_recreate": true,
        "build": false
      }
    }]
  },
  "webservice": {
    "services": [{
      "service": "dsmctl-gateway",
      "display_name": "dsmctl Gateway",
      "support_alias": true,
      "support_server": false,
      "type": "reverse_proxy",
      "proxy_target": "http://127.0.0.1:18765",
      "proxy_http_version": 1,
      "proxy_headers": [{
        "name": "Host",
        "value": "127.0.0.1"
      }, {
        "name": "X-Forwarded-Proto",
        "value": "$scheme"
      }, {
        "name": "X-Forwarded-Host",
        "value": "$http_host"
      }, {
        "name": "X-Forwarded-Prefix",
        "value": "/dsmctl"
      }],
      "connect_timeout": 10,
      "read_timeout": 180,
      "send_timeout": 30
    }],
    "portals": [{
      "service": "dsmctl-gateway",
      "name": "dsmctl-gateway",
      "display_name": "dsmctl Gateway",
      "app": "com.dsmctl.Gateway",
      "type": "alias",
      "alias": "dsmctl"
    }]
  }
}

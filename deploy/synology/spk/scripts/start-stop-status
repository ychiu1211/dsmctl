#!/bin/sh
set -eu

# Container lifecycle is owned by Synology's docker-project resource worker.
# This script contributes only a local process-health status check.
case "${1:-}" in
    start|stop)
        exit 0
        ;;
    status)
        if ! /usr/bin/wget -q -T 2 -O /dev/null http://127.0.0.1:18765/healthz; then
            exit 3
        fi
        exit 0
        ;;
    *)
        exit 2
        ;;
esac

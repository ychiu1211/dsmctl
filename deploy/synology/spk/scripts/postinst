#!/bin/sh
set -eu

umask 077
pkg="${SYNOPKG_PKGNAME:?}"
target="${SYNOPKG_PKGDEST:?}"
data_dir="${SYNOPKG_PKGVAR:?}"
home_dir="${SYNOPKG_PKGHOME:?}"
secret_dir="$home_dir/secrets"
mkdir -p "$data_dir" "$data_dir/backups" "$secret_dir"

if [ ! -f "$secret_dir/master.key" ]; then
    dd if=/dev/urandom of="$secret_dir/master.key" bs=32 count=1 2>/dev/null
fi
chmod 0600 "$secret_dir/master.key"

uid="$(id -u "$pkg")"
gid="$(id -g "$pkg")"
cat > "$target/project/.env" <<EOF
DSMCTL_UID=$uid
DSMCTL_GID=$gid
DSMCTL_DATA_DIR=$data_dir
DSMCTL_MASTER_KEY=$secret_dir/master.key
EOF
chmod 0600 "$target/project/.env"
echo "Offline image prepared. Open /dsmctl/admin through the DSM HTTPS portal within one hour after the package starts." > "${SYNOPKG_TEMP_LOGFILE:-/dev/null}"
exit 0

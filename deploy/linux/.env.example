# Use the repository@sha256 value published with a release. Tags are rejected
# by policy even though Compose itself would accept one.
DSMCTL_IMAGE=ghcr.io/ychiu1211/dsmctl-gateway@sha256:REPLACE_WITH_RELEASE_DIGEST
DSMCTL_UID=10001
DSMCTL_GID=10001
DSMCTL_DATA_DIR=/opt/dsmctl/data
DSMCTL_SECRET_DIR=/opt/dsmctl/secrets
DSMCTL_PORT=18765
DSMCTL_PUBLIC_ORIGIN=https://gateway.example.com
